def get_valid_attendance(student_name):
    # This function asks the user for attendance input
    # It will keep asking until a valid input (1 or 0) is entered
    
    while True:
        # Display instructions for the user
        print(f"\nEnter attendance for {student_name}")
        print("1 = PRESENT")
        print("0 = ABSENT")

        try:
            # Take input and convert it to integer
            status = int(input("Your input: "))

            if status == 1:
                print(f"{student_name} is marked PRESENT")
                return 1
            elif status == 0:
                print(f"{student_name} is marked ABSENT")
                return 0
            else:
                print("Invalid input. Please enter only 1 or 0.")

        except ValueError:
            # Handles non-integer inputs (e.g., letters, symbols)
            print("Invalid input. Please enter a number (1 or 0).")
