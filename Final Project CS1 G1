def get_valid_attendance(student_name):
    # This function asks the user for attendance input
    # It will keep asking until a valid input (1 or 0) is entered
    
    while True:
        # Display instructions for the user
        print(f"\nEnter attendance for {student_name}")
        print("1 = PRESENT")
        print("0 = ABSENT")

        try:
            # Take input and convert it to integer
            status = int(input("Your input: "))

            if status == 1:
                print(f"{student_name} is marked PRESENT")
                return 1
            elif status == 0:
                print(f"{student_name} is marked ABSENT")
                return 0
            else:
                print("Invalid input. Please enter only 1 or 0.")

        except ValueError:
            # Handles non-integer inputs (e.g., letters, symbols)
            print("Invalid input. Please enter a number (1 or 0).")

def check_attendance(student_names):

    #This function processes attendance for all students
    present_count = 0 # Counter for present students
    absent_counts = 0 # Counter for absent students

    #Loop through each student in the list
    for student in student_names:

        # call the function to get valid attendance input
        status = get_valid_attendance(student)

        if status == 1: # If student is present
            present_count += 1 # Increase present counter

        else: # If student is absent
            absent_count += 1 # Increase absent counter

    # Return the final counts
    return present_count, absent_count
